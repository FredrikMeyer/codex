{
  "compilerOptions": {
    "checkJs": true,
    "allowJs": true,
    "noEmit": true,
    "strict": true,
    "module": "ESNext",
    "moduleResolution": "bundler",
    "target": "ES2022",
    "lib": ["ES2022", "DOM"],
    "types": ["@js-temporal/polyfill"]
  },
  "include": ["*.js", "*.d.ts"],
  "exclude": ["service-worker.js", "test/**"]
}
